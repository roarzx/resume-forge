generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resumes   Resume[]

  @@map("users")
}

model Resume {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String    @default("我的简历")
  template       String    @default("classic")
  content        String    @default("{}")
  shareToken     String?   @unique
  sharePassword  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("resumes")
}

model Job {
  id          String     @id @default(cuid())
  title       String
  company     String?
  city        String?
  source      String     // "boss" | "linkedin" | "indeed"
  sourceUrl   String
  salary      String?
  tags        String?    // JSON array of skill tags for matching
  description String?
  fetchedAt   DateTime   @default(now())
  expiresAt   DateTime?  // cache expiry, null = no expiry
  clicks      JobClick[]

  @@map("jobs")
}

model JobClick {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String?
  createdAt DateTime @default(now())

  @@map("job_clicks")
}
